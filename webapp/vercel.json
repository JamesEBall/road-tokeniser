{
  "headers": [
    {
      "source": "/tiles/(.*).pmtiles",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.pmtiles" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=300" }
      ]
    }
  ],
  "cleanUrls": true
}
