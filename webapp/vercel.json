{
  "headers": [
    {
      "source": "/(.*).geojson",
      "headers": [
        { "key": "Content-Type", "value": "application/geo+json" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=300" }
      ]
    }
  ],
  "cleanUrls": true
}
